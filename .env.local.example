# ─── SUPABASE ───────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── STRIPE ─────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── RESEND (Email) ──────────────────────────────────────────
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_YOUR_KEY
EMAIL_FROM=orders@hoorabscollection.com

# ─── ADMIN ───────────────────────────────────────────────────
# Create a strong password for the admin area
ADMIN_EMAIL=hoorab@hoorabscollection.com
NEXT_PUBLIC_SITE_URL=https://hoorabscollection.com

